generator client {
  provider        = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                 String         @id @default(uuid())
  clerkId            String         @unique
  email              String         @unique
  name               String?
  role               String         @default("personal")
  credits            Int            @default(0)
  subscriptionStatus String         @default("inactive")
  subscriptionEnd    DateTime?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  pdfPremiumEnd      DateTime?
  subscriptionTier   String         @default("none")
  certificates       Certificate[]
  transactions       Transaction[]
  verifications      Verification[]
}

model Transaction {
  id              String   @id @default(uuid())
  userId          String
  amount          Int
  type            String
  status          String   @default("pending")
  tier            String?  // Plan name (daily, weekly, monthly, etc)
  failureReason   String?  // Description of why a transaction failed
  stripeSessionId String?  @unique
  mpesaCode       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id])
}

model Verification {
  id           String   @id @default(uuid())
  userId       String
  kraPin       String
  taxpayerName String?
  result       Json
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id])
}

model Certificate {
  id           String   @id @default(uuid())
  userId       String
  kraPin       String
  taxpayerName String?
  pdfUrl       String?
  details      Json?
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id])
}

model UsageLimit {
  id     String   @id @default(uuid())
  userId String
  type   String   // 'KRA' or 'PDF'
  date   DateTime @default(now())
  count  Int      @default(0)

  @@unique([userId, type, date])
}

model Notification {
  id        String   @id @default(uuid())
  message   String
  type      String   // 'marquee' or 'popup'
  theme     String   @default("purple") // 'purple', 'blue', 'green', 'pink', 'gold'
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
