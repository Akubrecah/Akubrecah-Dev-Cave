generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                 String         @id @default(uuid())
  clerkId            String         @unique
  email              String         @unique
  name               String?
  role               String         @default("personal")
  credits            Int            @default(0)
  subscriptionStatus String         @default("inactive")
  subscriptionEnd    DateTime?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  pdfPremiumEnd      DateTime?
  subscriptionTier   String         @default("none")
  theme              String?        @default("dark")
  certificates       Certificate[]
  transactions       Transaction[]
  verifications      Verification[]
  contactMessages    ContactMessage[]
  notifications      UserNotification[]
  usageLimits        UsageLimit[]
}

model Transaction {
  id              String   @id @default(uuid())
  userId          String?
  amount          Int      // Amount in subunits (e.g. cents for USD, kobo/subunit for KES)
  type            String
  status          String   @default("pending")
  paymentReference String?  @unique
  mpesaCode       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  tier            String?
  failureReason   String?
  user            User?     @relation(fields: [userId], references: [id])
}

model Verification {
  id            String   @id @default(uuid())
  userId        String
  kraPin        String?
  taxpayerName  String?
  type          String   @default("legacy") // 'kra_pin', 'nil_return', etc.
  status        String   @default("pending")
  data          Json?    // Store search parameters or original result
  result        Json?    // Store the result data for verification
  createdAt     DateTime @default(now())
  updatedAt     DateTime @default(now()) @updatedAt
  user          User     @relation(fields: [userId], references: [id])
}

model Certificate {
  id            String   @id @default(uuid())
  userId        String
  kraPin        String
  taxpayerName  String
  type          String   @default("KRA") // 'PIN', 'NIL_RETURN'
  content       String   @default("") @db.Text // Base64 content of the PDF (DEPRECATED: Use pdfContent instead)
  pdfContent    String?  @db.Text
  details       Json?
  fileName      String   @default("untitled.pdf")
  createdAt     DateTime @default(now())
  user          User     @relation(fields: [userId], references: [id])
}

model ContactMessage {
  id          String   @id @default(uuid())
  userId      String
  name        String?
  email       String?
  subject     String
  message     String   @db.Text
  status      String   @default("pending") // 'pending', 'resolved'
  resolution  String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id])
}

model UserNotification {
  id        String   @id @default(uuid())
  userId    String
  message   String   @db.Text
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model TscResource {
  id          String   @id @default(uuid())
  title       String
  description String?  @db.Text
  fileContent String?  @db.Text
  fileUrl     String?
  fileName    String
  fileType    String   @default("application/pdf")
  size        Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model UsageLimit {
  id        String   @id @default(uuid())
  userId    String
  type      String   // 'KRA', 'PDF', etc.
  date      DateTime @default(now())
  count     Int      @default(1)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type, date])
}

model Notification {
  id        String   @id @default(uuid())
  message   String   @db.Text
  type      String   // 'marquee', 'popup'
  active    Boolean  @default(true)
  theme     String   @default("purple")
  speed     Int      @default(30)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model NavigationSetting {
  id         String   @id @default(uuid())
  href       String   @unique
  label      String
  isHidden   Boolean  @default(false)
  isDisabled Boolean  @default(false)
  updatedAt  DateTime @updatedAt
}

