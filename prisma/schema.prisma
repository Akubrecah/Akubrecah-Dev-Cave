generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                 String         @id @default(uuid())
  clerkId            String         @unique
  email              String         @unique
  name               String?
  role               String         @default("personal")
  credits            Int            @default(0)
  subscriptionStatus String         @default("inactive")
  subscriptionEnd    DateTime?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  pdfPremiumEnd      DateTime?
  subscriptionTier   String         @default("none")
  certificates       Certificate[]
  transactions       Transaction[]
  verifications      Verification[]
  contactMessages    ContactMessage[]
  notifications      UserNotification[]
}

model Transaction {
  id              String   @id @default(uuid())
  userId          String?
  amount          Int      // Amount in subunits (e.g. cents for USD, kobo/subunit for KES)
  type            String
  status          String   @default("pending")
  paymentReference String?  @unique
  mpesaCode       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  tier            String?
  failureReason   String?
  user            User?     @relation(fields: [userId], references: [id])
}

model Verification {
  id           String   @id @default(uuid())
  userId       String
  kraPin       String
  taxpayerName String?
  result       Json
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id])
}

model Certificate {
  id           String   @id @default(uuid())
  userId       String
  kraPin       String
  taxpayerName String?
  pdfUrl       String?
  pdfContent   String? @db.Text  // Base64 encoded PDF data
  createdAt    DateTime @default(now())
  details      Json?
  user         User     @relation(fields: [userId], references: [id])
}

model UsageLimit {
  id     String   @id @default(uuid())
  userId String
  type   String
  date   DateTime @default(now())
  count  Int      @default(0)

  @@unique([userId, type, date])
}

model Notification {
  id        String   @id @default(uuid())
  message   String
  type      String   // 'marquee' or 'popup'
  theme     String   @default("purple")
  customTheme String?  @db.Text
  active    Boolean  @default(false)
  speed     Int      @default(30)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ContactMessage {
  id          String   @id @default(uuid())
  userId      String
  name        String
  email       String
  subject     String
  message     String   @db.Text
  status      String   @default("pending") // 'pending', 'resolved'
  resolution  String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id])
}

model UserNotification {
  id        String   @id @default(uuid())
  userId    String
  message   String   @db.Text
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}
